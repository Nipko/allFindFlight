# Copy to .env.prod and fill before deploying. NEVER commit .env.prod.

# Postgres
POSTGRES_PASSWORD=replace-with-strong-password

# Cloudflare Tunnel token (Zero Trust > Networks > Tunnels > <your tunnel>)
TUNNEL_TOKEN=replace-with-tunnel-token

# Image registry (optional; defaults to ghcr.io/nipko)
REGISTRY=ghcr.io/nipko
IMAGE_TAG=latest

# External APIs (optional)
GOOGLE_MAPS_API_KEY=
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
TRAVELPAYOUTS_TOKEN=

# Scraping proxy (optional)
PROXY_URL=
