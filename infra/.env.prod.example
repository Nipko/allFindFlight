# Copia a .env.prod o pega estas variables en el panel "Environment variables" de Portainer.
# NUNCA comitar .env.prod.

# Postgres (corre internamente en 55432)
POSTGRES_PASSWORD=replace-with-strong-password

# Cloudflare Tunnel token (Zero Trust > Networks > Tunnels)
TUNNEL_TOKEN=replace-with-tunnel-token

# Registry y tag de imagen
REGISTRY=ghcr.io/nipko
IMAGE_TAG=latest

# APIs externas (opcionales)
GOOGLE_MAPS_API_KEY=
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
TRAVELPAYOUTS_TOKEN=

# Proxy de scraping (opcional)
PROXY_URL=
