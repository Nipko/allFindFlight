# Copia a infra/.env.prod en el VPS y rellena. NUNCA comitar .env.prod.
# (setup-vps.sh lo crea automáticamente la primera vez.)

# Postgres (corre internamente en 55432)
POSTGRES_PASSWORD=replace-with-strong-password

# Cloudflare Tunnel token (Zero Trust > Networks > Tunnels)
TUNNEL_TOKEN=replace-with-tunnel-token

# Registry y tag de imagen
REGISTRY=ghcr.io/nipko
IMAGE_TAG=latest

# APIs externas (opcionales)
GOOGLE_MAPS_API_KEY=
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
TRAVELPAYOUTS_TOKEN=

# Proxy de scraping (opcional)
PROXY_URL=
